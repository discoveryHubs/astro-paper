---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={[
    "w-full border-t border-border bg-soft",
    { "mt-auto": !noMarginTop },
    className,
  ]}
  {...attrs}
>
  <div class="mx-auto max-w-7xl px-6 py-10">

    <div class="grid gap-8 sm:grid-cols-3">

      <!-- Brand / About -->
      <div class="space-y-3">
        <h3 class="text-lg font-semibold tracking-tight">YourBrand</h3>
        <p class="text-sm text-muted leading-relaxed">
          Independent digital publishing platform focused on performance,
          usability, and modern web standards.
        </p>
      </div>

      <!-- Author / EEAT Section -->
      <div class="space-y-3">
        <h4 class="text-sm font-semibold uppercase tracking-wide text-muted">
          Editorial Lead
        </h4>
        <p class="text-sm font-medium">
          Zeeshan Haider
        </p>
        <p class="text-sm text-muted">
          Research-driven content creator focused on clarity, technical accuracy,
          and user-first experience.
        </p>
      </div>

      <!-- Social + Legal -->
      <div class="flex flex-col items-start space-y-4 sm:items-end">
        <Socials />

        <div class="text-sm text-muted text-left sm:text-right">
          <div>© {currentYear} Zeeshan Haider</div>
          <div>All rights reserved.</div>
        </div>
      </div>

    </div>

  </div>
</footer>