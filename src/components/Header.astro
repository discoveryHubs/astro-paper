---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header class="w-full border-b border-border bg-background/85 backdrop-blur-md">
  <div class="mx-auto w-full max-w-7xl px-4 sm:px-6">
    <div
      id="top-nav-wrap"
      class:list={[
        "py-4 sm:py-5",
        "relative w-full",
        "flex items-center justify-between",
      ]}
    >
      <a
        href="/"
        class="py-1 text-xl font-semibold tracking-tight whitespace-nowrap sm:text-2xl hover:text-accent transition"
      >
        {SITE.title}
      </a>

      <nav
        id="nav-menu"
        class="flex items-center"
      >
        <button
          id="menu-btn"
          class="focus-outline p-2 sm:hidden"
          aria-label="Open Menu"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <IconX id="close-icon" class="hidden" />
          <IconMenuDeep id="menu-icon" />
        </button>

        <ul
          id="menu-items"
          class:list={[
            // Mobile dropdown
            "hidden sm:flex",
            "absolute sm:static top-full right-0 left-0 sm:left-auto sm:right-auto",
            "mt-3 sm:mt-0",
            "bg-background sm:bg-transparent",
            "border border-border sm:border-0 rounded-xl sm:rounded-none",
            "shadow-lg sm:shadow-none",
            "p-3 sm:p-0",
            "grid sm:flex",
            "grid-cols-2 sm:grid-cols-none",
            "gap-2 sm:gap-6",
            "[&>li>a]:block",
            "[&>li>a]:px-3 [&>li>a]:py-2 sm:[&>li>a]:px-0 sm:[&>li>a]:py-0",
            "[&>li>a]:text-center sm:[&>li>a]:text-left",
            "[&>li>a]:text-sm [&>li>a]:font-medium",
            "[&>li>a]:rounded-lg sm:[&>li>a]:rounded-none",
            "[&>li>a]:hover:text-accent",
            "[&>li>a]:hover:bg-muted/60 sm:[&>li>a]:hover:bg-transparent",
          ]}
        >
          <li class="col-span-2 sm:col-span-1">
            <a
              href="/posts"
              class:list={[
                isActive("/posts") ? "active-nav text-accent" : "",
              ]}
            >
              Posts
            </a>
          </li>

          <li class="col-span-2 sm:col-span-1">
            <a
              href="/tags"
              class:list={[
                isActive("/tags") ? "active-nav text-accent" : "",
              ]}
            >
              Tags
            </a>
          </li>

          <li class="col-span-2 sm:col-span-1">
            <a
              href="/about"
              class:list={[
                isActive("/about") ? "active-nav text-accent" : "",
              ]}
            >
              About
            </a>
          </li>

          {
            SITE.showArchives && (
              <li class="col-span-2 sm:col-span-1">
                <LinkButton
                  href="/archives"
                  class:list={[
                    "focus-outline inline-flex items-center justify-center gap-1.5 px-3 py-2 sm:px-0 sm:py-0 rounded-lg sm:rounded-none",
                    "hover:bg-muted/60 sm:hover:bg-transparent",
                    {
                      "active-nav text-accent [&>svg]:stroke-accent": isActive("/archives"),
                    },
                  ]}
                  title="Archives"
                  aria-label="archives"
                >
                  <IconArchive class="hidden sm:inline-block" />
                  <span class="sm:sr-only">Archives</span>
                  <span class="sm:hidden">Archives</span>
                </LinkButton>
              </li>
            )
          }

          <li class="col-span-1 flex items-center justify-center sm:justify-start">
            <LinkButton
              href="/search"
              class:list={[
                "focus-outline inline-flex items-center justify-center gap-1.5 px-3 py-2 sm:px-0 sm:py-0 rounded-lg sm:rounded-none",
                "hover:bg-muted/60 sm:hover:bg-transparent",
                { "text-accent [&>svg]:stroke-accent": isActive("/search") },
              ]}
              title="Search"
              aria-label="search"
            >
              <IconSearch />
              <span class="sr-only">Search</span>
              <span class="sm:hidden">Search</span>
            </LinkButton>
          </li>

          {
            SITE.lightAndDarkMode && (
              <li class="col-span-1 flex items-center justify-center sm:justify-start">
                <button
                  id="theme-btn"
                  class="focus-outline relative size-11 sm:size-9 p-3 sm:p-2 rounded-lg hover:bg-muted/60 sm:hover:bg-transparent hover:[&>svg]:stroke-accent"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                >
                  <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </button>
              </li>
            )
          }
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);
</script>