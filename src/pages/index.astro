---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />

  <main id="main-content" data-layout="index" class="w-full" data-pagefind-body>
    <!-- FULL BLEED HERO (100% width) -->
    <section
      class="relative left-1/2 right-1/2 -mx-[50vw] w-screen overflow-hidden border-b border-border"
    >
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute -top-40 left-1/2 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-accent/15 blur-3xl"></div>
        <div class="absolute -bottom-48 -right-40 h-[520px] w-[520px] rounded-full bg-accent/10 blur-3xl"></div>
      </div>

      <div class="app-layout relative py-14 sm:py-20">
        <div class="grid items-center gap-10 lg:grid-cols-12">
          <div class="lg:col-span-7">
            <div class="inline-flex items-center gap-2 rounded-full border border-border bg-background/60 px-3 py-1 text-xs font-semibold backdrop-blur">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              <span>Astro + Tailwind UI Test</span>
            </div>

            <h1 class="mt-5 text-4xl font-bold tracking-tight sm:text-6xl">
              {SITE.title}
            </h1>

            <p class="mt-5 max-w-2xl text-base leading-7 opacity-90 sm:text-lg">
              Professional full-width landing layout, clean typography, strong spacing,
              and fast UI patterns. This is only for speed and layout testing.
            </p>

            <div class="mt-7 flex flex-wrap items-center gap-3">
              <LinkButton
                href="/posts/"
                class="inline-flex items-center gap-2 rounded-xl bg-accent px-5 py-3 text-sm font-semibold text-background shadow-sm hover:opacity-95"
              >
                Explore Posts
                <IconArrowRight class="inline-block rtl:-rotate-180" />
              </LinkButton>

              <LinkButton
                href="/about/"
                class="inline-flex items-center gap-2 rounded-xl border border-border bg-background px-5 py-3 text-sm font-semibold hover:text-accent"
              >
                About
                <IconArrowRight class="inline-block rtl:-rotate-180" />
              </LinkButton>

              <a
                target="_blank"
                href="/rss.xml"
                class="inline-flex items-center gap-2 rounded-xl border border-border bg-background px-4 py-3 text-sm font-semibold hover:text-accent"
                aria-label="rss feed"
                title="RSS Feed"
              >
                <IconRss width={18} height={18} class="stroke-current" />
                <span>RSS</span>
              </a>
            </div>

            {SOCIALS.length > 0 && (
              <div class="mt-7 flex max-sm:flex-col sm:items-center">
                <div class="me-3 mb-2 whitespace-nowrap text-sm font-semibold opacity-80 sm:mb-0">
                  Social:
                </div>
                <Socials />
              </div>
            )}
          </div>

          <div class="lg:col-span-5">
            <div class="rounded-2xl border border-border bg-background/70 p-6 shadow-sm backdrop-blur">
              <div class="flex items-center justify-between">
                <div class="text-sm font-semibold opacity-80">Dashboard</div>
                <div class="text-xs font-semibold opacity-70">
                  Updated {new Date().toLocaleDateString()}
                </div>
              </div>

              <div class="mt-5 grid grid-cols-3 gap-3">
                <div class="rounded-xl border border-border bg-background p-4 text-center">
                  <div class="text-2xl font-bold">{sortedPosts.length}</div>
                  <div class="mt-1 text-xs opacity-75">Total Posts</div>
                </div>
                <div class="rounded-xl border border-border bg-background p-4 text-center">
                  <div class="text-2xl font-bold">{featuredPosts.length}</div>
                  <div class="mt-1 text-xs opacity-75">Featured</div>
                </div>
                <div class="rounded-xl border border-border bg-background p-4 text-center">
                  <div class="text-2xl font-bold">{SITE.postPerIndex}</div>
                  <div class="mt-1 text-xs opacity-75">Home Limit</div>
                </div>
              </div>

              <div class="mt-5 rounded-xl border border-border bg-background p-4">
                <div class="text-sm font-semibold">Performance Notes</div>
                <ul class="mt-2 space-y-1 text-sm opacity-90">
                  <li class="flex gap-2">
                    <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-accent"></span>
                    <span>Full-bleed sections with constrained content container.</span>
                  </li>
                  <li class="flex gap-2">
                    <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-accent"></span>
                    <span>Use explicit image width/height to avoid layout shift.</span>
                  </li>
                  <li class="flex gap-2">
                    <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-accent"></span>
                    <span>Keep hero background gradients lightweight.</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FULL BLEED FEATURE STRIP -->
    <section
      class="relative left-1/2 right-1/2 -mx-[50vw] w-screen border-b border-border bg-muted/20"
    >
      <div class="app-layout py-10 sm:py-14">
        <div class="grid gap-6 md:grid-cols-3">
          <div class="rounded-2xl border border-border bg-background p-6 shadow-sm">
            <div class="text-xs font-semibold opacity-70">Design</div>
            <h2 class="mt-3 text-lg font-bold">Clean, modern spacing</h2>
            <p class="mt-2 text-sm leading-6 opacity-90">
              Proper rhythm, card hierarchy, and readable typography for a professional feel.
            </p>
          </div>

          <div class="rounded-2xl border border-border bg-background p-6 shadow-sm">
            <div class="text-xs font-semibold opacity-70">Speed</div>
            <h2 class="mt-3 text-lg font-bold">Light UI, low overhead</h2>
            <p class="mt-2 text-sm leading-6 opacity-90">
              Utility-first styling with minimal custom CSS to keep builds fast and stable.
            </p>
          </div>

          <div class="rounded-2xl border border-border bg-background p-6 shadow-sm">
            <div class="text-xs font-semibold opacity-70">Structure</div>
            <h2 class="mt-3 text-lg font-bold">SEO-friendly layout</h2>
            <p class="mt-2 text-sm leading-6 opacity-90">
              Clear sections and headings make content scanning easy for users and crawlers.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CONTENT AREA (constrained, but sections above are 100% width) -->
    <section class="app-layout py-10 sm:py-14">
      {featuredPosts.length > 0 && (
        <div class="pb-10">
          <div class="flex items-baseline justify-between">
            <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
            <LinkButton
              href="/posts/"
              class="text-sm font-semibold underline decoration-dashed underline-offset-4 hover:text-accent"
            >
              View all
            </LinkButton>
          </div>

          <ul class="mt-5">
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </div>
      )}

      {recentPosts.length > 0 && (
        <div class="pt-2">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul class="mt-5">
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </div>
      )}

      <div class="my-12 text-center">
        <LinkButton
          href="/posts/"
          class="inline-flex items-center gap-2 rounded-xl border border-border bg-background px-6 py-3 text-sm font-semibold hover:text-accent"
        >
          All Posts
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const el = document.querySelector("#main-content");
    if (!(el instanceof HTMLElement)) return;

    const layout = el.dataset.layout;
    if (layout) sessionStorage.setItem("backUrl", "/");
  });
</script>