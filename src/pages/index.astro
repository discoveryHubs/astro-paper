---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

// Inline SVG icons (no extra requests)
const IconBolt = (props: { class?: string; width?: number; height?: number }) => (
  <svg
    width={props.width ?? 22}
    height={props.height ?? 22}
    viewBox="0 0 24 24"
    fill="none"
    class={props.class ?? ""}
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M13 2L3 14h7l-1 8 12-14h-7l1-6z" />
  </svg>
);

const IconShield = (props: { class?: string; width?: number; height?: number }) => (
  <svg
    width={props.width ?? 22}
    height={props.height ?? 22}
    viewBox="0 0 24 24"
    fill="none"
    class={props.class ?? ""}
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M12 2l8 4v6c0 5-3.5 9.5-8 10-4.5-.5-8-5-8-10V6l8-4z" />
    <path d="M9 12l2 2 4-5" />
  </svg>
);

const IconSpark = (props: { class?: string; width?: number; height?: number }) => (
  <svg
    width={props.width ?? 22}
    height={props.height ?? 22}
    viewBox="0 0 24 24"
    fill="none"
    class={props.class ?? ""}
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M12 2l1.2 4.2L17 8l-3.8 1.8L12 14l-1.2-4.2L7 8l3.8-1.8L12 2z" />
    <path d="M5 13l.8 2.8L8 17l-2.2 1.2L5 21l-.8-2.8L2 17l2.2-1.2L5 13z" />
    <path d="M19 13l.8 2.8L22 17l-2.2 1.2L19 21l-.8-2.8L16 17l2.2-1.2L19 13z" />
  </svg>
);
---

<Layout>
  <Header />

  <!-- Full-width hero band, content stays max-width via app-layout -->
  <main id="main-content" data-layout="index" class="w-full">
    <section class="relative w-full border-b border-border">
      <!-- subtle background -->
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -top-24 left-1/2 h-72 w-[46rem] -translate-x-1/2 rounded-full bg-accent/10 blur-3xl"></div>
        <div class="absolute -bottom-28 right-0 h-72 w-72 rounded-full bg-muted/60 blur-3xl"></div>
      </div>

      <div class="app-layout relative pt-10 pb-10 sm:pt-14 sm:pb-14">
        <div class="flex flex-col gap-8">
          <div class="flex items-start justify-between gap-6">
            <div class="max-w-2xl">
              <div class="inline-flex items-center gap-2 rounded-full border border-border bg-background/60 px-3 py-1 text-xs font-medium backdrop-blur">
                <span class="inline-block size-2 rounded-full bg-accent"></span>
                Fast, clean, and SEO-ready
              </div>

              <h1 class="mt-4 text-4xl font-bold leading-tight tracking-tight sm:text-5xl">
                A Custom Home That Looks Premium
                <span class="block text-accent">and Stays Lightweight</span>
              </h1>

              <p class="mt-4 text-base leading-7 opacity-90 sm:text-lg">
                Yeh home page sirf speed test aur design test ke liye hai. Tailwind utilities,
                inline SVG icons, aur minimal DOM use kiya gaya hai.
              </p>

              <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
                <LinkButton href="/posts/" class="w-full justify-center sm:w-auto">
                  Explore Posts
                  <IconArrowRight class="inline-block rtl:-rotate-180" />
                </LinkButton>

                <a
                  href="/rss.xml"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex w-full items-center justify-center gap-2 rounded-md border border-border bg-background/60 px-4 py-2 text-sm font-medium hover:text-accent backdrop-blur sm:w-auto"
                  aria-label="rss feed"
                  title="RSS Feed"
                >
                  <IconRss width={18} height={18} class="scale-110 stroke-accent stroke-3 rtl:-rotate-90" />
                  RSS Feed
                </a>
              </div>

              {SOCIALS.length > 0 && (
                <div class="mt-6 flex flex-col gap-2 sm:flex-row sm:items-center">
                  <div class="text-sm opacity-80">Connect:</div>
                  <Socials />
                </div>
              )}
            </div>

            <div class="hidden min-w-[280px] max-w-[340px] flex-1 sm:block">
              <div class="rounded-2xl border border-border bg-background/60 p-5 shadow-sm backdrop-blur">
                <div class="flex items-center justify-between">
                  <div class="text-sm font-semibold">Live Speed Targets</div>
                  <span class="rounded-full bg-muted px-2 py-1 text-xs">LCP Focus</span>
                </div>

                <div class="mt-4 grid gap-3">
                  <div class="flex items-center justify-between rounded-xl border border-border bg-background px-4 py-3">
                    <div class="flex items-center gap-2">
                      <IconBolt class="text-accent" />
                      <span class="text-sm font-medium">Images</span>
                    </div>
                    <span class="text-sm opacity-80">Optimized</span>
                  </div>

                  <div class="flex items-center justify-between rounded-xl border border-border bg-background px-4 py-3">
                    <div class="flex items-center gap-2">
                      <IconShield class="text-accent" />
                      <span class="text-sm font-medium">CSS</span>
                    </div>
                    <span class="text-sm opacity-80">Minimal</span>
                  </div>

                  <div class="flex items-center justify-between rounded-xl border border-border bg-background px-4 py-3">
                    <div class="flex items-center gap-2">
                      <IconSpark class="text-accent" />
                      <span class="text-sm font-medium">JS</span>
                    </div>
                    <span class="text-sm opacity-80">Very Low</span>
                  </div>
                </div>

                <div class="mt-4 rounded-xl border border-border bg-background px-4 py-3">
                  <div class="text-xs opacity-75">Tip</div>
                  <div class="mt-1 text-sm">
                    Agar aap heavy images use karoge to LCP down ho jata hai.
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Feature strip -->
          <div class="grid gap-4 sm:grid-cols-3">
            <div class="rounded-2xl border border-border bg-background/60 p-5 shadow-sm backdrop-blur">
              <div class="flex items-center gap-3">
                <span class="inline-flex size-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
                  <IconBolt />
                </span>
                <div>
                  <div class="text-sm font-semibold">Fast by Design</div>
                  <div class="text-sm opacity-80">Low JS, clean markup</div>
                </div>
              </div>
            </div>

            <div class="rounded-2xl border border-border bg-background/60 p-5 shadow-sm backdrop-blur">
              <div class="flex items-center gap-3">
                <span class="inline-flex size-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
                  <IconShield />
                </span>
                <div>
                  <div class="text-sm font-semibold">Stable Layout</div>
                  <div class="text-sm opacity-80">No CLS surprises</div>
                </div>
              </div>
            </div>

            <div class="rounded-2xl border border-border bg-background/60 p-5 shadow-sm backdrop-blur">
              <div class="flex items-center gap-3">
                <span class="inline-flex size-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
                  <IconSpark />
                </span>
                <div>
                  <div class="text-sm font-semibold">SEO Friendly</div>
                  <div class="text-sm opacity-80">Semantic sections</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured -->
    {featuredPosts.length > 0 && (
      <section class="app-layout pt-10 pb-6">
        <div class="flex items-end justify-between gap-4">
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <span class="text-sm opacity-70">Top picks</span>
        </div>
        <ul class="mt-4">
          {featuredPosts.map(data => (
            <Card variant="h3" {...data} />
          ))}
        </ul>
      </section>
    )}

    <!-- Recent -->
    {recentPosts.length > 0 && (
      <section class="app-layout pt-6 pb-8">
        <div class="flex items-end justify-between gap-4">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <span class="text-sm opacity-70">Latest updates</span>
        </div>

        <ul class="mt-4">
          {recentPosts.map(
            (data, index) =>
              index < SITE.postPerIndex && <Card variant="h3" {...data} />
          )}
        </ul>

        <div class="mt-10 text-center">
          <LinkButton href="/posts/">
            All Posts
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = document.querySelector("#main-content")?.dataset?.layout;
    if (indexLayout) sessionStorage.setItem("backUrl", "/");
  });
</script>