---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />

  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-10", "border-b border-border"]}>
      <div class="w-full">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
          <div class="max-w-2xl">
            <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-6xl">
              Mingalaba
            </h1>
            <p class="mt-4 text-base leading-7 opacity-90 sm:text-lg">
              Minimal, fast, and clean Astro blog. This homepage is a styling test with
              full-width sections, SVG icons, and Tailwind utilities.
            </p>

            <div class="mt-6 flex flex-wrap items-center gap-3">
              <LinkButton
                href="/posts/"
                class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 font-semibold text-background hover:opacity-90"
              >
                Browse Posts
                <IconArrowRight class="inline-block rtl:-rotate-180" />
              </LinkButton>

              <LinkButton
                href="/about/"
                class="inline-flex items-center gap-2 rounded-lg border border-border bg-background px-4 py-2 font-semibold hover:text-accent"
              >
                About
                <IconArrowRight class="inline-block rtl:-rotate-180" />
              </LinkButton>

              <a
                target="_blank"
                href="/rss.xml"
                class="inline-flex items-center gap-2 rounded-lg border border-border bg-background px-3 py-2 hover:text-accent"
                aria-label="rss feed"
                title="RSS Feed"
              >
                <IconRss width={18} height={18} class="stroke-current" />
                <span class="text-sm font-medium">RSS</span>
              </a>
            </div>

            {SOCIALS.length > 0 && (
              <div class="mt-6 flex max-sm:flex-col sm:items-center">
                <div class="me-2 mb-1 whitespace-nowrap sm:mb-0 opacity-80">
                  Social Links:
                </div>
                <Socials />
              </div>
            )}
          </div>

          <div class="w-full sm:w-[22rem]">
            <div class="rounded-2xl border border-border bg-muted/25 p-5">
              <div class="text-sm font-semibold opacity-80">Quick Stats</div>
              <div class="mt-4 grid grid-cols-3 gap-3 text-center">
                <div class="rounded-xl border border-border bg-background p-3">
                  <div class="text-2xl font-bold">{sortedPosts.length}</div>
                  <div class="text-xs opacity-80">Posts</div>
                </div>
                <div class="rounded-xl border border-border bg-background p-3">
                  <div class="text-2xl font-bold">{featuredPosts.length}</div>
                  <div class="text-xs opacity-80">Featured</div>
                </div>
                <div class="rounded-xl border border-border bg-background p-3">
                  <div class="text-2xl font-bold">{SITE.postPerIndex}</div>
                  <div class="text-xs opacity-80">On Home</div>
                </div>
              </div>

              <div class="mt-4 rounded-xl border border-border bg-background p-3 text-sm opacity-90">
                Tip: Keep images in <span class="font-semibold">/public</span> and use
                <span class="font-semibold"> /filename.jpg</span> paths in markdown.
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-10">
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-border bg-background p-6">
          <div class="text-sm font-semibold opacity-80">Performance Focus</div>
          <h2 class="mt-3 text-xl font-bold">Clean layout, fewer shifts</h2>
          <p class="mt-2 text-sm leading-6 opacity-90">
            Full-width sections with constrained content using app-layout.
            Keep CLS stable by giving images fixed width and height.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-background p-6">
          <div class="text-sm font-semibold opacity-80">Design System</div>
          <h2 class="mt-3 text-xl font-bold">Theme variables driven</h2>
          <p class="mt-2 text-sm leading-6 opacity-90">
            Background, border, muted, and accent are controlled by CSS variables.
            Tailwind utilities use those tokens.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-background p-6">
          <div class="text-sm font-semibold opacity-80">SEO Ready</div>
          <h2 class="mt-3 text-xl font-bold">Readable, structured content</h2>
          <p class="mt-2 text-sm leading-6 opacity-90">
            Proper headings and consistent spacing improves scannability and
            helps Google understand layout.
          </p>
        </div>
      </div>
    </section>

    {featuredPosts.length > 0 && (
      <section
        id="featured"
        class:list={[
          "pt-6 pb-6",
          { "border-b border-border": recentPosts.length > 0 },
        ]}
      >
        <div class="flex items-baseline justify-between">
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <LinkButton
            href="/posts/"
            class="text-sm font-semibold underline decoration-dashed underline-offset-4 hover:text-accent"
          >
            View all
          </LinkButton>
        </div>

        <ul class="mt-4">
          {featuredPosts.map(data => (
            <Card variant="h3" {...data} />
          ))}
        </ul>
      </section>
    )}

    {recentPosts.length > 0 && (
      <section id="recent-posts" class="pt-10 pb-6">
        <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
        <ul class="mt-4">
          {recentPosts.map(
            (data, index) =>
              index < SITE.postPerIndex && <Card variant="h3" {...data} />
          )}
        </ul>
      </section>
    )}

    <div class="my-10 text-center">
      <LinkButton
        href="/posts/"
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-background px-5 py-3 font-semibold hover:text-accent"
      >
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const el = document.querySelector("#main-content");

    if (!(el instanceof HTMLElement)) return;

    const indexLayout = el.dataset.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>